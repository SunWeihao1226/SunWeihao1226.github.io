---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.displayname }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
          {% endif %}
          {% capture sizes %}(min-width: {{ site.max_width }}) {{ site.max_width | minus: 30 | times: 0.3}}px, (min-width: 576px) 30vw, 95vw"{% endcapture %}
          {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes=sizes alt=page.profile.image cache_bust=true %}
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Experience -->
    {% assign featured_experience = site.experience | where: "featured", true | sort: "importance" %}
    {% if featured_experience.size > 0 %}
      <h2>Experience</h2>
      {% for item in featured_experience limit: 4 %}
        <div class="row mt-3 mb-3">
          {% if item.img %}
            <div class="col-sm-2">
              <img
                src="{{ item.img | relative_url }}"
                alt="{{ item.title }}"
                class="img-fluid rounded"
                style="width: 110px; height: 110px; object-fit: cover;"
              >
            </div>
          {% endif %}
          <div class="{% if item.img %}col-sm-10{% else %}col-sm-12{% endif %}">
            <h5 class="mb-1" style="font-size: 1rem; font-weight: 400;">
              {% if item.redirect %}
                <a href="{{ item.redirect }}">{{ item.position }}</a>
              {% else %}
                {{ item.position }}
              {% endif %}
            </h5>

            {% if item.organization or item.date_range %}
              <p class="mb-1" style="font-size: 0.95rem;">
                {% if item.organization %}{{ item.organization }}{% endif %}
                {% if item.organization and item.date_range %}, {% endif %}
                {% if item.date_range %}{{ item.date_range }}{% endif %}
              </p>
            {% endif %}

            {% if item.description %}
              <p class="mb-1" style="font-size: 0.95rem; line-height: 1.4;">
                {{ item.description | markdownify }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endif %}

    <!-- Selected projects -->
    {% assign featured_projects = site.projects | where: "featured", true | sort: "importance" %}
    {% if featured_projects.size > 0 %}
      <h2><a href="{{ '/projects/' | relative_url }}" style="color: inherit">Selected projects</a></h2>
      {% for project in featured_projects limit: 3 %}
        <div class="row mt-3 mb-3">
          {% if project.img %}
            <div class="col-sm-2">
              <img
                src="{{ project.img | relative_url }}"
                alt="{{ project.title }}"
                class="img-fluid rounded"
                style="width: 110px; height: 110px; object-fit: cover;"
              >
            </div>
          {% endif %}

          <div class="{% if project.img %}col-sm-9{% else %}col-sm-12{% endif %}">
            <h5 class="mb-1" style="color: black;">
              {{ project.title }}
            </h5>

            {% if project.description %}
              <p class="mb-1">{{ project.description }}</p>
            {% endif %}

            <p class="mb-0">
              {% if project.redirect %}
                <a href="{{ project.redirect }}">View project</a>
              {% elsif project.github %}
                <a href="{{ project.github }}">View project</a>
              {% else %}
                <a href="{{ project.url | relative_url }}">View project</a>
              {% endif %}
            </p>
          </div>
        </div>
      {% endfor %}
    {% endif %}



    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% social_links %}</div>
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>